{
  "name": "chaipoll-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "npm run test:server && npm run test:client",
    "test:all": "npm run test:server && npm run test:client && npm run test:e2e",
    "test:server": "npm --prefix server test",
    "test:client": "vitest run",
    "test:e2e": "playwright test",
    "playwright:install": "playwright install chromium",
    "lint": "npm run lint:web && npm run lint:server",
    "lint:web": "eslint .",
    "lint:server": "npm --prefix server run lint",
    "lint:fix": "eslint . --fix && npm --prefix server run lint:fix",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.node.json",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@playwright/test": "^1.52.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^15.14.0",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.7.3",
    "vite": "^5.4.11",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "axios": "^1.16.0",
    "framer-motion": "^12.38.0",
    "lenis": "^1.3.23",
    "lucide-react": "^1.14.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-rough-notation": "^1.0.8",
    "react-router-dom": "^7.15.0",
    "reactflow": "^11.11.4",
    "recharts": "^3.8.1",
    "rough-notation": "^0.5.1",
    "roughjs": "^4.6.6",
    "socket.io-client": "^4.8.3"
  }
}
