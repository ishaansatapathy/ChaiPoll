PORT=5000
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/chaipoll
JWT_SECRET=your_super_secret_jwt_key
CLIENT_URL=http://localhost:5173
# Optional: overrides CORS + Socket.io origins (comma-separated). Use in production with every frontend origin.
# ALLOWED_ORIGINS=http://localhost:5173,https://your-app.vercel.app
NODE_ENV=development

# JWT cookie: dev defaults to SameSite=lax, Secure=false (http://localhost). Production defaults to none+Secure.
# JWT_COOKIE_SAMESITE=lax
# JWT_COOKIE_SECURE=false

# Brevo (transactional email — required for password reset)
BREVO_API_KEY=
BREVO_SENDER_EMAIL=noreply@your-verified-domain.com
# BREVO_SENDER_NAME=ChaiPoll
# Optional aliases (sendEmail also reads these if the BREVO_* vars are unset):
# FROM_EMAIL=
# FROM_NAME=

# OAuth Config (Optional for local, required for production)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
